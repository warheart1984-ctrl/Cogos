#!/bin/sh
set -eu

export PATH=/bin:/sbin:/usr/bin:/usr/sbin:/opt/cogos/bin
export COGOS_ROOT=/opt/cogos
export COGOS_LOG=/var/log/cogos-pid1.log

PROOF=/opt/cogos/memory/logs/pid1_proof.json
BOOT_REPORT=/opt/cogos/memory/logs/boot_report.json
DAEMON_PID=/run/cogos-daemon.pid
NATIVE_INIT=/usr/sbin/init.original

mkdir -p /proc /sys /dev /run /tmp /var/log /opt/cogos/memory/logs
rm -f "$PROOF"
mountpoint -q /proc || mount -t proc proc /proc || true
mountpoint -q /sys || mount -t sysfs sysfs /sys || true
mountpoint -q /dev || mount -t devtmpfs devtmpfs /dev || mount -t tmpfs dev /dev || true
mountpoint -q /run || mount -t tmpfs tmpfs /run || true
mountpoint -q /tmp || mount -t tmpfs tmpfs /tmp || true

log() {
  printf '%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo boot)" "$*" | tee -a "$COGOS_LOG" >/dev/null
}

write_proof() {
  status="$1"
  reason="${2:-}"
  daemon_status="${3:-not_started}"
  python3 - "$PROOF" "$status" "$reason" "$daemon_status" "$NATIVE_INIT" "$$" <<'PY' 2>/dev/null || true
import hashlib
import json
import pathlib
import sys
import time

proof_path = pathlib.Path(sys.argv[1])
status, reason, daemon_status, handoff_target, pid = sys.argv[2:7]
root = pathlib.Path("/opt/cogos")
manifest_path = root / "law" / "law_manifest.json"

def sha256_file(path: pathlib.Path):
    try:
        h = hashlib.sha256()
        with path.open("rb") as fh:
            for chunk in iter(lambda: fh.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None

law_files = []
law_integrity = False
try:
    manifest = json.loads(manifest_path.read_text(encoding="utf-8-sig"))
    for item in manifest.get("files", []):
        path = pathlib.Path(item["path"])
        actual = sha256_file(path)
        law_files.append({
            "path": str(path),
            "expected": item.get("sha256"),
            "actual": actual,
            "ok": actual == item.get("sha256"),
        })
    law_integrity = bool(law_files) and all(item["ok"] for item in law_files)
except Exception as exc:
    law_files.append({"error": str(exc), "path": str(manifest_path), "ok": False})

proof = {
    "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    "pid": int(pid),
    "pid1_gate_ok": status == "ok",
    "status": status,
    "reason": reason,
    "law_integrity": law_integrity,
    "law_files": law_files,
    "boot_report": "/opt/cogos/memory/logs/boot_report.json",
    "daemon_status": daemon_status,
    "daemon_pid_file": "/run/cogos-daemon.pid",
    "handoff_target": handoff_target,
    "handoff_mode": "exec_native_init_original",
}
proof_path.parent.mkdir(parents=True, exist_ok=True)
proof_path.write_text(json.dumps(proof, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

write_basic_proof() {
  status="$1"
  reason="$2"
  cat > "$PROOF" <<EOF
{
  "boot_report": "$BOOT_REPORT",
  "daemon_status": "not_started",
  "handoff_mode": "fail_closed_maintenance_shell",
  "handoff_target": "$NATIVE_INIT",
  "law_integrity": false,
  "pid": $$,
  "pid1_gate_ok": false,
  "reason": "$reason",
  "status": "$status"
}
EOF
}

fail_closed() {
  reason="$1"
  log "FAIL CLOSED: $reason"
  if command -v python3 >/dev/null 2>&1; then
    write_proof "failed" "$reason" "not_started"
  else
    write_basic_proof "failed" "$reason"
  fi
  exec /bin/sh
}

log "Project Infi cognitive_init starting as PID $$"
[ "$$" = "1" ] || log "warning: cognitive_init expected PID 1 but is PID $$"

log "Stage: mount runtime surfaces"
log "Stage: load root law"
[ -f /opt/cogos/law/root_law.json ] || fail_closed "root_law missing"
[ -x "$NATIVE_INIT" ] || fail_closed "native init handoff target missing: $NATIVE_INIT"
command -v python3 >/dev/null 2>&1 || fail_closed "python3 missing"

log "Stage: governed boot verification"
python3 /opt/cogos/bin/cogos_boot.py --boot >> "$COGOS_LOG" 2>&1 || fail_closed "governed boot verification failed"
[ -s "$BOOT_REPORT" ] || fail_closed "boot report was not written"

log "Stage: start governed daemon"
python3 /opt/cogos/bin/cogos_daemon.py --daemon >> /var/log/cogos-service.log 2>&1 &
echo $! > "$DAEMON_PID"
sleep 1
if ! kill -0 "$(cat "$DAEMON_PID")" 2>/dev/null; then
  fail_closed "governed daemon failed to stay running"
fi

write_proof "ok" "" "running"
[ -s "$PROOF" ] || fail_closed "PID 1 proof was not written"
log "Stage: PID 1 gate complete; handoff to $NATIVE_INIT"
exec "$NATIVE_INIT"
